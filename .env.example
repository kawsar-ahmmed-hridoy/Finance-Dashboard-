# Application
NODE_ENV=development
PORT=3000
APP_NAME="Finance Dashboard API"

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-this-to-a-strong-password
DB_NAME=finance_db
DB_SYNC=false
DB_LOGGING=false

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-a-different-long-random-secret
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3001,http://localhost:4200
TRUST_PROXY=false

# Swagger (disabled by default; only enable locally when needed)
SWAGGER_ENABLED=false

# Seed script credentials (required only for seeding)
SEED_ADMIN_PASSWORD=Admin@1234
SEED_ANALYST_PASSWORD=Analyst@1234
SEED_VIEWER_PASSWORD=Viewer@1234

