# Application
NODE_ENV=development
PORT=3000
APP_NAME="Finance Dashboard API"

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-this-to-a-strong-password
DB_NAME=finance_db
DB_SYNC=false
DB_LOGGING=false

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-a-different-long-random-secret
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3001,http://localhost:4200

# Swagger (enable only in local dev)
SWAGGER_ENABLED=true

# Seed script credentials (required only for seeding)
SEED_ADMIN_PASSWORD=change-this-admin-password
SEED_ANALYST_PASSWORD=change-this-analyst-password
SEED_VIEWER_PASSWORD=change-this-viewer-password
